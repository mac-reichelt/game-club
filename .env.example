# Game Club environment variables
# Copy this file to .env.local for local development

# RAWG API key for game search (optional).
# Get a free key at https://rawg.io/apidocs
# Without this, the game-search/import feature is disabled (returns 503).
RAWG_API_KEY=

# Invite code required for new member sign-up.
# Set this to a strong random string (e.g. `openssl rand -hex 24`).
# Share this value only with people you want to allow to join.
# Rotating this value invalidates future sign-ups but does NOT log out existing members.
# If this variable is not set, sign-up is DISABLED (fail-closed).
SIGNUP_INVITE_CODE=
